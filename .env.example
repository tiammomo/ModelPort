# ModelPort local server.
MODELPORT_BIND=127.0.0.1:17878
MODELPORT_AUTH_TOKEN=replace-with-a-local-router-token
MODELPORT_DEFAULT_PROVIDER=mimo
MODELPORT_MAX_REQUEST_BODY_BYTES=33554432
MODELPORT_MAX_CONCURRENT_REQUESTS=64

# Native HTTP transport.
MODELPORT_HTTP_CONNECT_TIMEOUT_SECS=10
MODELPORT_HTTP_REQUEST_TIMEOUT_SECS=600
MODELPORT_HTTP_STREAM_IDLE_TIMEOUT_SECS=300
MODELPORT_HTTP_MAX_RESPONSE_BYTES=33554432

# DeepSeek official Anthropic-compatible API.
DEEPSEEK_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_ANTHROPIC_AUTH_TOKEN=replace-with-deepseek-api-key

# Xiaomi/Mimo third-party OpenAI-compatible API.
# Many third-party dashboards expose this generic BASE_URL name.
BASE_URL=https://w.ciykj.cn/v1
# MIMO_OPENAI_BASE_URL overrides BASE_URL when both are set.
# MIMO_OPENAI_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_OPENAI_API_KEY=replace-with-mimo-api-key
MIMO_MODEL=mimo-v2.5-pro

# Optional upstream providers. Set the key to auto-enable the provider.
# OPENAI_API_KEY=replace-with-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
#
# ANTHROPIC_API_KEY=replace-with-anthropic-api-key
# ANTHROPIC_UPSTREAM_BASE_URL=https://api.anthropic.com
# ANTHROPIC_UPSTREAM_MODEL=claude-sonnet-4-20250514
#
# OPENROUTER_API_KEY=replace-with-openrouter-api-key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openrouter/auto
#
# GEMINI_API_KEY=replace-with-gemini-api-key
# GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# GEMINI_MODEL=gemini-2.5-flash
#
# XAI_API_KEY=replace-with-xai-api-key
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_MODEL=grok-3
#
# GROQ_API_KEY=replace-with-groq-api-key
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_MODEL=llama-3.3-70b-versatile
#
# DASHSCOPE_API_KEY=replace-with-dashscope-api-key
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_MODEL=qwen-plus
#
# MOONSHOT_API_KEY=replace-with-kimi-api-key
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_MODEL=kimi-k2.6
#
# ZHIPU_API_KEY=replace-with-zhipu-api-key
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPU_MODEL=glm-4.7
#
# MISTRAL_API_KEY=replace-with-mistral-api-key
# MISTRAL_BASE_URL=https://api.mistral.ai/v1
# MISTRAL_MODEL=mistral-large-latest
#
# ARK_API_KEY=replace-with-volcengine-ark-api-key
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=doubao-seed-1-6-250615
#
# MODELPORT_ENABLE_OLLAMA=1
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=llama3.1
#
# CUSTOM_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
# CUSTOM_OPENAI_API_KEY=optional-custom-key
# CUSTOM_OPENAI_MODEL=default

# Claude Code can point at ModelPort with these variables.
ANTHROPIC_BASE_URL=http://127.0.0.1:17878
ANTHROPIC_AUTH_TOKEN=replace-with-the-same-local-router-token
ANTHROPIC_MODEL=mimo-v2.5-pro
ANTHROPIC_DEFAULT_OPUS_MODEL=mimo-v2.5-pro
ANTHROPIC_DEFAULT_SONNET_MODEL=mimo-v2.5-pro
ANTHROPIC_DEFAULT_HAIKU_MODEL=mimo-v2.5-pro
ANTHROPIC_SMALL_FAST_MODEL=mimo-v2.5-pro
CLAUDE_CODE_SUBAGENT_MODEL=mimo-v2.5-pro
