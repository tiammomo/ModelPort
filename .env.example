# ModelPort complete local environment reference
# ==============================================
# Copy to .env only for process-based local development. Docker Compose should
# start from deploy/docker/modelport.env.example; systemd should start from
# deploy/systemd/modelport.env.example. Never commit a populated environment file.
#
# Configuration sources and precedence:
#   process/container environment > MODELPORT_ENV_FILE or cwd/.env > built-in defaults
#   config.toml defines provider records/order/aliases; environment supplies secrets.
#   persisted dashboard overrides are applied after the base provider configuration.
#
# Choose one upstream topology before starting:
#   A. DeepSeek only: keep the DeepSeek block and MODELPORT_DEFAULT_PROVIDER=deepseek.
#   B. Local Qwen only: use a TOML local_qwen provider, set QWEN_LOCAL_BASE_URL,
#      set MODELPORT_DEFAULT_PROVIDER=local_qwen, and omit every DeepSeek key.
#   C. Both: use TOML provider_order=["local_qwen","deepseek"], keep both endpoints,
#      and choose one explicit default. Provider presence is not automatic verification.
#
# Client/server credential boundary:
#   MODELPORT_AUTH_TOKEN is a legacy gateway CLIENT token accepted by the data plane.
#   Dashboard-issued scoped API keys are preferred for QuantPilot/team clients.
#   DEEPSEEK_ANTHROPIC_AUTH_TOKEN and other provider keys are SERVER upstream secrets;
#   never copy them into QuantPilot or an SDK client environment.
#
# Validation: scripts/config-validate.sh
# Full reference: docs/CONFIGURATION.md

# Local server, published ports, authentication, and dashboard bootstrap.
MODELPORT_BIND=127.0.0.1:38082
MODELPORT_API_PUBLISH=127.0.0.1:38082
MODELPORT_DASHBOARD_PUBLISH=127.0.0.1:33002
MODELPORT_AUTH_TOKEN=replace-with-a-local-router-token
MODELPORT_ADMIN_USERNAME=admin
MODELPORT_ADMIN_PASSWORD=replace-with-a-long-random-admin-password
# MODELPORT_ADMIN_EMAIL=admin@modelport.local
# MODELPORT_ADMIN_SESSION_TTL_SECONDS=43200
# Enable when the dashboard is served over HTTPS.
# MODELPORT_ADMIN_COOKIE_SECURE=1

# Optional console OIDC sign-in. Disabled by default; uncomment the required
# issuer, client ID, and redirect URI together to enable it. The callback path
# is fixed at /admin/auth/oidc/callback.
# MODELPORT_OIDC_ISSUER=https://identity.example.com/realms/modelport
# MODELPORT_OIDC_CLIENT_ID=modelport
# MODELPORT_OIDC_REDIRECT_URI=https://modelport.example.com/admin/auth/oidc/callback
# Optional for a confidential client; omit for a supported public client.
# MODELPORT_OIDC_CLIENT_SECRET=replace-with-client-secret
# MODELPORT_OIDC_LABEL=Company SSO
# Automatic user provisioning is off by default; pre-create users initially.
# MODELPORT_OIDC_AUTO_PROVISION=0
# MODELPORT_OIDC_USERNAME_CLAIM=preferred_username
# MODELPORT_OIDC_EMAIL_CLAIM=email
# Loopback development only; never permit remote production OIDC over HTTP.
# MODELPORT_OIDC_ALLOW_INSECURE_HTTP=1
# Production OIDC also requires HTTPS cookie/origin hardening and data-plane keys:
# MODELPORT_ADMIN_COOKIE_SECURE=1
# MODELPORT_ALLOWED_ORIGINS=https://modelport.example.com
# MODELPORT_REQUIRE_CONTROL_API_KEYS=1

# Must name an enabled provider in environment templates, TOML, or dashboard overrides.
MODELPORT_DEFAULT_PROVIDER=deepseek
# MODELPORT_CONFIG=config.toml
# MODELPORT_ENV_FILE=.env
# MODELPORT_STATE_DIR=.modelport
# MODELPORT_AUTH_STORE_PATH=.modelport/admin-auth.json
# MODELPORT_CONTROL_STORE=.modelport/control-plane.json
# MODELPORT_DATABASE_URL=postgres://modelport:password@127.0.0.1:5432/modelport
# Optional separate database for the normalized request/attempt ledger.
# MODELPORT_ENTERPRISE_DATABASE_URL=postgres://modelport:password@127.0.0.1:5432/modelport
# PostgreSQL TLS: disable, allow, prefer, require, verify-ca, or verify-full.
# MODELPORT_DATABASE_TLS_MODE=prefer
# MODELPORT_DATABASE_MAX_CONNECTIONS=16
# MODELPORT_DATABASE_MIN_CONNECTIONS=0
# MODELPORT_DATABASE_ACQUIRE_TIMEOUT_SECS=10
# Active requests renew this lease every one-third TTL; expired rows are reconciled.
# MODELPORT_LEDGER_LEASE_TTL_SECS=300
# MODELPORT_LEDGER_RECONCILE_INTERVAL_SECS=60
# Production profile: requires MODELPORT_DATABASE_URL and verify-full TLS.
# MODELPORT_ENTERPRISE_MODE=1
MODELPORT_USAGE_LOG_LIMIT=5000
MODELPORT_MAX_REQUEST_BODY_BYTES=33554432
MODELPORT_MAX_CONCURRENT_REQUESTS=64
# Defaults to MODELPORT_MAX_CONCURRENT_REQUESTS; 429 when all stream permits are held.
# MODELPORT_MAX_CONCURRENT_STREAMS=64
MODELPORT_RATE_LIMIT_WINDOW_SECONDS=60
MODELPORT_RATE_LIMIT_GLOBAL_PER_MINUTE=6000
MODELPORT_RATE_LIMIT_API_KEY_PER_MINUTE=600
MODELPORT_RATE_LIMIT_IP_PER_MINUTE=1200
MODELPORT_RATE_LIMIT_PROVIDER_PER_MINUTE=3000
MODELPORT_RATE_LIMIT_MODEL_PER_MINUTE=1200
MODELPORT_MAX_MODEL_NAME_CHARS=240
MODELPORT_MAX_MESSAGES=200
MODELPORT_MAX_MESSAGES_JSON_CHARS=2097152
MODELPORT_MAX_SYSTEM_JSON_CHARS=262144
MODELPORT_MAX_TOOLS=256
MODELPORT_MAX_TOOLS_JSON_CHARS=1048576
# POST /v1/messages requires max_tokens > 0 and rejects values above this cap.
MODELPORT_MAX_OUTPUT_TOKENS=131072
# Team/shared deployments can require dashboard-issued API keys for /v1 and /metrics.
# MODELPORT_REQUIRE_CONTROL_API_KEYS=1
# Keep detailed provider health behind auth by default.
# MODELPORT_EXPOSE_DETAILED_HEALTH=1
# Only enable for trusted internal networks with private provider base URLs.
# MODELPORT_ALLOW_PRIVATE_PROVIDER_URLS=1
# Remote providers require HTTPS. This exposes API keys and prompts in plaintext;
# use only for a trusted internal HTTP upstream; local/custom HTTP is unaffected.
# MODELPORT_ALLOW_INSECURE_PROVIDER_HTTP=1

# Native HTTP transport.
MODELPORT_HTTP_CONNECT_TIMEOUT_SECS=10
# Complete non-stream timeout; SSE uses this for handshake and error-body total reads.
MODELPORT_HTTP_REQUEST_TIMEOUT_SECS=600
# Established SSE and error-body reads reset this timeout on every chunk.
MODELPORT_HTTP_STREAM_IDLE_TIMEOUT_SECS=300
MODELPORT_HTTP_MAX_RESPONSE_BYTES=33554432
MODELPORT_HTTP_SSE_MAX_LINE_BYTES=1048576
MODELPORT_HTTP_SSE_MAX_EVENT_BYTES=8388608
MODELPORT_HTTP_SSE_MAX_STREAM_BYTES=67108864
# MODELPORT_HTTP_USER_AGENT=model-port/0.1.0

# DeepSeek official Anthropic-compatible API.
# This entire block may be removed for a Qwen-only deployment. The balance action uses
# this same upstream credential server-side and never returns it to the browser/client.
DEEPSEEK_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_ANTHROPIC_AUTH_TOKEN=replace-with-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional local Qwen runtime used by the maintained QuantPilot integration.
# A TOML [providers.local_qwen] record is required; the environment-only `custom`
# template does not create the provider name `local_qwen`. In Docker use the shared
# runtime DNS name; for a host process use the reachable loopback URL.
# QWEN_LOCAL_BASE_URL=http://qwen-runtime:8080/v1

# Optional Xiaomi/Mimo OpenAI-compatible API.
# Many third-party dashboards expose this generic BASE_URL name.
# BASE_URL=https://w.ciykj.cn/v1
# MIMO_OPENAI_BASE_URL overrides BASE_URL when both are set.
# MIMO_OPENAI_BASE_URL=https://api.xiaomimimo.com/v1
# MIMO_OPENAI_API_KEY=replace-with-mimo-api-key
# MIMO_MODEL=mimo-v2.5-pro

# Optional upstream providers. Set the key to auto-enable the provider.
# DEEPSEEK_OPENAI_API_KEY=replace-with-deepseek-api-key
# DEEPSEEK_OPENAI_BASE_URL=https://api.deepseek.com
# DEEPSEEK_OPENAI_MODEL=deepseek-v4-flash
#
# OpenAI upstream settings for the ModelPort server. Keep these separate from
# client-side OPENAI_* variables that point an SDK back to ModelPort.
# MODELPORT_OPENAI_API_KEY=replace-with-openai-api-key
# MODELPORT_OPENAI_BASE_URL=https://api.openai.com/v1
# MODELPORT_OPENAI_MODEL=gpt-5.5
# MODELPORT_OPENAI_MODELS=gpt-5.5,gpt-5.4,gpt-4.1
# Legacy OPENAI_API_KEY/BASE_URL/MODEL/MODELS remain warning-producing fallbacks.
#
# ANTHROPIC_API_KEY=replace-with-anthropic-api-key
# ANTHROPIC_UPSTREAM_BASE_URL=https://api.anthropic.com
# ANTHROPIC_UPSTREAM_MODEL=claude-fable-5
#
# OPENROUTER_API_KEY=replace-with-openrouter-api-key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openrouter/auto
#
# GEMINI_API_KEY=replace-with-gemini-api-key
# GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# GEMINI_MODEL=gemini-3.5-flash
#
# XAI_API_KEY=replace-with-xai-api-key
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_MODEL=grok-3
#
# GROQ_API_KEY=replace-with-groq-api-key
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_MODEL=llama-3.3-70b-versatile
#
# DASHSCOPE_API_KEY=replace-with-dashscope-api-key
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_MODEL=qwen-plus
#
# MOONSHOT_API_KEY=replace-with-kimi-api-key
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_MODEL=kimi-k2.6
#
# ZHIPU_API_KEY=replace-with-zhipu-api-key
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPU_MODEL=glm-4.7
#
# MISTRAL_API_KEY=replace-with-mistral-api-key
# MISTRAL_BASE_URL=https://api.mistral.ai/v1
# MISTRAL_MODEL=mistral-large-latest
#
# ARK_API_KEY=replace-with-volcengine-ark-api-key
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=doubao-seed-1-6-250615
#
# MODELPORT_ENABLE_OLLAMA=1
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=llama3.1
#
# CUSTOM_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
# CUSTOM_OPENAI_API_KEY=optional-custom-key
# CUSTOM_OPENAI_MODEL=default

# Claude Code can point at ModelPort with these variables.
ANTHROPIC_BASE_URL=http://127.0.0.1:38082
ANTHROPIC_AUTH_TOKEN=replace-with-the-same-local-router-token
ANTHROPIC_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
ANTHROPIC_SMALL_FAST_MODEL=deepseek-v4-flash
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
