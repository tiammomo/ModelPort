# Local bind address. Keep 127.0.0.1 unless a reverse proxy is in front.
MODELPORT_BIND=127.0.0.1:17878
MODELPORT_AUTH_TOKEN=replace-with-a-long-random-local-token
MODELPORT_ADMIN_USERNAME=admin
MODELPORT_ADMIN_PASSWORD=replace-with-a-long-random-admin-password
MODELPORT_DEFAULT_PROVIDER=deepseek
MODELPORT_MAX_REQUEST_BODY_BYTES=33554432
MODELPORT_MAX_CONCURRENT_REQUESTS=64
MODELPORT_RATE_LIMIT_GLOBAL_PER_MINUTE=6000
MODELPORT_RATE_LIMIT_API_KEY_PER_MINUTE=600
MODELPORT_RATE_LIMIT_IP_PER_MINUTE=1200
MODELPORT_RATE_LIMIT_PROVIDER_PER_MINUTE=3000
MODELPORT_RATE_LIMIT_MODEL_PER_MINUTE=1200
MODELPORT_MAX_MODEL_NAME_CHARS=240
MODELPORT_MAX_MESSAGES=200
MODELPORT_MAX_MESSAGES_JSON_CHARS=2097152
MODELPORT_MAX_SYSTEM_JSON_CHARS=262144
MODELPORT_MAX_TOOLS=256
MODELPORT_MAX_TOOLS_JSON_CHARS=1048576
MODELPORT_MAX_OUTPUT_TOKENS=131072
# Optional PostgreSQL persistence. If set, auth/control state is stored in
# PostgreSQL table modelport_state instead of local JSON files.
# MODELPORT_DATABASE_URL=postgres://modelport:replace-with-password@127.0.0.1:5432/modelport
MODELPORT_TRUSTED_PROXIES=127.0.0.1,::1
# MODELPORT_ALLOWED_ORIGINS=http://127.0.0.1:5173
# MODELPORT_DISABLE_CSRF=1
# MODELPORT_REQUIRE_CONTROL_API_KEYS=1
# MODELPORT_EXPOSE_DETAILED_HEALTH=1
# MODELPORT_ALLOW_PRIVATE_PROVIDER_URLS=1

# Native HTTP transport.
MODELPORT_HTTP_CONNECT_TIMEOUT_SECS=10
MODELPORT_HTTP_REQUEST_TIMEOUT_SECS=600
MODELPORT_HTTP_STREAM_IDLE_TIMEOUT_SECS=300
MODELPORT_HTTP_MAX_RESPONSE_BYTES=33554432

# DeepSeek official Anthropic-compatible API.
DEEPSEEK_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_ANTHROPIC_AUTH_TOKEN=replace-with-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional Xiaomi/Mimo OpenAI-compatible API.
# BASE_URL=https://w.ciykj.cn/v1
# MIMO_OPENAI_API_KEY=replace-with-real-mimo-api-key
# MIMO_MODEL=mimo-v2.5-pro

# Claude Code / VS Code Claude should use the same local token.
ANTHROPIC_BASE_URL=http://127.0.0.1:17878
ANTHROPIC_AUTH_TOKEN=replace-with-the-same-local-router-token
ANTHROPIC_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
ANTHROPIC_SMALL_FAST_MODEL=deepseek-v4-flash
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
