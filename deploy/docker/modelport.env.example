# Copy to .env before running docker compose:
#   cp deploy/docker/modelport.env.example .env
#
# Keep the published ports on 127.0.0.1 for personal use. Change to
# 0.0.0.0:17878 / 0.0.0.0:5173 only when your LAN or reverse proxy should reach it.
MODELPORT_API_PUBLISH=127.0.0.1:17878
MODELPORT_DASHBOARD_PUBLISH=127.0.0.1:5173

# Container runtime. docker-compose.yml overrides MODELPORT_BIND to 0.0.0.0:17878
# inside the container, so this value is mainly useful for local scripts.
MODELPORT_BIND=127.0.0.1:17878
MODELPORT_AUTH_TOKEN=replace-with-a-long-random-local-token
MODELPORT_ADMIN_USERNAME=admin
MODELPORT_ADMIN_PASSWORD=replace-with-a-long-random-admin-password
MODELPORT_DEFAULT_PROVIDER=deepseek
MODELPORT_ADMIN_SESSION_TTL_SECONDS=43200

# Optional console OIDC sign-in. It is disabled by default. Set the three
# required values together; the callback path is always /admin/auth/oidc/callback.
# MODELPORT_OIDC_ISSUER=https://identity.example.com/realms/modelport
# MODELPORT_OIDC_CLIENT_ID=modelport
# MODELPORT_OIDC_REDIRECT_URI=https://modelport.example.com/admin/auth/oidc/callback
# Optional confidential-client secret.
# MODELPORT_OIDC_CLIENT_SECRET=replace-with-client-secret
# MODELPORT_OIDC_LABEL=Company SSO
# Automatic provisioning is off by default; pre-create users initially.
# MODELPORT_OIDC_AUTO_PROVISION=0
# MODELPORT_OIDC_USERNAME_CLAIM=preferred_username
# MODELPORT_OIDC_EMAIL_CLAIM=email
# Loopback development only; never enable for a remote production identity
# provider.
# MODELPORT_OIDC_ALLOW_INSECURE_HTTP=1
# Production OIDC hardening:
# MODELPORT_ADMIN_COOKIE_SECURE=1
# MODELPORT_ALLOWED_ORIGINS=https://modelport.example.com
# MODELPORT_REQUIRE_CONTROL_API_KEYS=1

MODELPORT_USAGE_LOG_LIMIT=5000
MODELPORT_MAX_REQUEST_BODY_BYTES=33554432
MODELPORT_MAX_CONCURRENT_REQUESTS=64
# Defaults to MODELPORT_MAX_CONCURRENT_REQUESTS; held until stream body completion/drop.
# MODELPORT_MAX_CONCURRENT_STREAMS=64
MODELPORT_RATE_LIMIT_WINDOW_SECONDS=60
MODELPORT_RATE_LIMIT_GLOBAL_PER_MINUTE=6000
MODELPORT_RATE_LIMIT_API_KEY_PER_MINUTE=600
MODELPORT_RATE_LIMIT_IP_PER_MINUTE=1200
MODELPORT_RATE_LIMIT_PROVIDER_PER_MINUTE=3000
MODELPORT_RATE_LIMIT_MODEL_PER_MINUTE=1200
MODELPORT_MAX_MODEL_NAME_CHARS=240
MODELPORT_MAX_MESSAGES=200
MODELPORT_MAX_MESSAGES_JSON_CHARS=2097152
MODELPORT_MAX_SYSTEM_JSON_CHARS=262144
MODELPORT_MAX_TOOLS=256
MODELPORT_MAX_TOOLS_JSON_CHARS=1048576
# POST /v1/messages requires max_tokens > 0 and rejects values above this cap.
MODELPORT_MAX_OUTPUT_TOKENS=131072

# PostgreSQL is internal to docker-compose by default. It does not publish 5432
# on the host, so it will not conflict with other PostgreSQL instances.
MODELPORT_POSTGRES_DB=modelport
MODELPORT_POSTGRES_USER=modelport
# Compose embeds this value in a connection URL. Use a long URL-safe value
# (letters, digits, `_`, `-`) unless you percent-encode reserved characters.
MODELPORT_POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
# Optional override when you need a fully percent-encoded connection URL.
# MODELPORT_DATABASE_URL=postgres://modelport:encoded-password@postgres:5432/modelport
# The internal Compose database has no TLS certificate; development defaults to
# `prefer` and falls back to the private bridge. Remote enterprise databases
# must use verify-full and a trusted sslrootcert in the URL.
# MODELPORT_DATABASE_TLS_MODE=prefer
# MODELPORT_DATABASE_MAX_CONNECTIONS=16
# MODELPORT_DATABASE_MIN_CONNECTIONS=0
# MODELPORT_DATABASE_ACQUIRE_TIMEOUT_SECS=10
# MODELPORT_LEDGER_LEASE_TTL_SECS=300
# MODELPORT_LEDGER_RECONCILE_INTERVAL_SECS=60
# MODELPORT_ENTERPRISE_DATABASE_URL=postgres://modelport:encoded-password@postgres:5432/modelport
# MODELPORT_ENTERPRISE_MODE=1

# Security hardening.
# Forwarded IP headers are trusted only from these proxy IPs/CIDRs. ModelPort
# strips trusted hops right-to-left; bundled Nginx overwrites XFF with remote_addr.
# The Docker dashboard container reaches the backend from the bridge network.
MODELPORT_TRUSTED_PROXIES=127.0.0.1,::1,172.16.0.0/12
# Optional comma-separated origins for console write requests when Host and Origin differ.
# MODELPORT_ALLOWED_ORIGINS=http://127.0.0.1:5173
# Emergency/local debugging only; do not enable in production.
# MODELPORT_DISABLE_CSRF=1
# Team/shared deployments can require dashboard-issued API keys for /v1 and /metrics.
# MODELPORT_REQUIRE_CONTROL_API_KEYS=1
# Keep detailed provider health behind auth by default.
# MODELPORT_EXPOSE_DETAILED_HEALTH=1
# Only enable for trusted internal networks with private provider base URLs.
# MODELPORT_ALLOW_PRIVATE_PROVIDER_URLS=1
# Remote providers require HTTPS. This exposes API keys and prompts in plaintext;
# use only for a trusted internal HTTP upstream; local/custom HTTP is unaffected.
# MODELPORT_ALLOW_INSECURE_PROVIDER_HTTP=1

# Native HTTP transport.
MODELPORT_HTTP_CONNECT_TIMEOUT_SECS=10
# Complete non-stream timeout; SSE uses this for handshake and error-body total reads.
MODELPORT_HTTP_REQUEST_TIMEOUT_SECS=600
# Established SSE and error-body reads reset this timeout on every chunk.
MODELPORT_HTTP_STREAM_IDLE_TIMEOUT_SECS=300
MODELPORT_HTTP_MAX_RESPONSE_BYTES=33554432
MODELPORT_HTTP_SSE_MAX_LINE_BYTES=1048576
MODELPORT_HTTP_SSE_MAX_EVENT_BYTES=8388608
MODELPORT_HTTP_SSE_MAX_STREAM_BYTES=67108864

# DeepSeek official Anthropic-compatible API.
DEEPSEEK_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_ANTHROPIC_AUTH_TOKEN=replace-with-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional Xiaomi/Mimo OpenAI-compatible API.
# BASE_URL=https://w.ciykj.cn/v1
# MIMO_OPENAI_API_KEY=replace-with-real-mimo-api-key
# MIMO_MODEL=mimo-v2.5-pro

# Optional OpenAI upstream for the ModelPort server. Do not use client-side
# OPENAI_BASE_URL=http://127.0.0.1:17878/v1 in this server environment.
# MODELPORT_OPENAI_API_KEY=replace-with-real-openai-api-key
# MODELPORT_OPENAI_BASE_URL=https://api.openai.com/v1
# MODELPORT_OPENAI_MODEL=gpt-5.5
# MODELPORT_OPENAI_MODELS=gpt-5.5,gpt-5.4,gpt-4.1

# Optional: local runtimes on the Docker host should use host.docker.internal.
# MODELPORT_ENABLE_OLLAMA=1
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# OLLAMA_MODEL=llama3.1
# CUSTOM_OPENAI_BASE_URL=http://host.docker.internal:8000/v1
# CUSTOM_OPENAI_API_KEY=optional-custom-key
# CUSTOM_OPENAI_MODEL=default

# Claude Code / VS Code Claude on the host should use the published API port.
ANTHROPIC_BASE_URL=http://127.0.0.1:17878
ANTHROPIC_AUTH_TOKEN=replace-with-the-same-local-router-token
ANTHROPIC_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
ANTHROPIC_SMALL_FAST_MODEL=deepseek-v4-flash
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
